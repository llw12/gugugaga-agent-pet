{
  "name": "gugugaga-agent-pet",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:desktop": "npm --prefix apps/desktop run dev",
    "dev:agent": "python -m uvicorn app.main:app --app-dir apps/agent-server --host 127.0.0.1 --port 8765",
    "build:desktop": "npm --prefix apps/desktop run build",
    "check:alpha": "node scripts/check-alpha.mjs",
    "test:agent": "python -m pytest apps/agent-server/tests",
    "check": "npm run build:desktop && npm run check:alpha && npm run test:agent",
    "tauri:dev": "npm --prefix apps/desktop run tauri dev",
    "dev": "npm run dev:desktop"
  }
}
